      "batch_success": "unsupported",
      "single_error": { "error": { "code": "stable browser error code", "buntingCode": "stable domain code when applicable", "message": "redacted stable message", "path": "procedure name", "data": "optional durable command outcome" } },
      "status": "HTTP status associated with the single browser response",
      "extra_headers": "security and correlation headers may be added by the Worker without changing the envelope"
    },
    "errors": {
